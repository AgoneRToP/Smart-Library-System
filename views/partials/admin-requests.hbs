<div id="admin-requests-panel"
  class="hidden fixed inset-0 bg-slate-900/40 backdrop-blur-sm flex items-center justify-center z-50">
  <div
    class="bg-white border border-slate-200 rounded-2xl p-6 shadow-xl w-full max-w-4xl relative mx-4 max-h-[85vh] flex flex-col">
    <button onclick="toggleModal('admin-requests-panel')"
      class="absolute top-4 right-4 text-slate-400 hover:text-slate-600 text-2xl font-semibold focus:outline-none">&times;</button>

    <div class="border-b border-slate-100 pb-4 mb-4 flex justify-between items-center shrink-0">
      <div>
        <h2 class="text-xl font-bold text-slate-900 flex items-center gap-2">📥 Запросы на аренду книг</h2>
        <p class="text-slate-500 text-sm mt-0.5">Подтверждение выдачи книг читателям и контроль возвратов.</p>
      </div>
      <button onclick="loadAdminRequests()"
        class="text-xs bg-slate-100 hover:bg-slate-200 text-slate-700 px-3 py-1.5 rounded-lg font-medium transition mr-8">🔄
        Обновить</button>
    </div>

    <div class="overflow-y-auto flex-1 pr-1">
      <table class="w-full text-sm text-left text-slate-500">
        <thead class="text-xs text-slate-700 uppercase bg-slate-50 sticky top-0 z-10">
          <tr>
            <th class="px-4 py-3">Читатель</th>
            <th class="px-4 py-3">Книга</th>
            <th class="px-4 py-3">Вернуть до</th>
            <th class="px-4 py-3">Статус</th>
            <th class="px-4 py-3 text-right">Действия</th>
          </tr>
        </thead>
        <tbody id="admin-requests-table-body">
          <tr>
            <td colspan="5" class="text-center py-4 text-slate-400">Загрузка...</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>