<!-- views/partials/navbar.hbs -->
<nav class="bg-white shadow-sm border-b border-slate-200 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <div class="flex items-center space-x-3">
      <span class="text-2xl">📚</span>
      <a href="/" class="font-bold text-xl tracking-tight text-indigo-600">SmartLibrary</a>
    </div>

    <div class="flex items-center space-x-4">
      <!-- КНОПКА ПОИСКА (ЛУПА) — Доступна всем категориям пользователей в любой момент -->
      <button onclick="openSearchModal()" class="p-2 text-slate-500 hover:text-indigo-600 hover:bg-indigo-50 rounded-xl transition处理 focus:outline-none flex items-center justify-center gap-1 font-medium text-sm" title="Открыть поиск книг">
        <span class="text-lg leading-none">🔍</span> 
        <span class="hidden sm:inline">Поиск</span>
      </button>

      <!-- Кнопки для гостей -->
      <button onclick="toggleModal('login-modal')" id="btn-nav-login"
        class="text-sm font-medium text-slate-600 hover:text-indigo-600 transition block">Войти</button>
      <button onclick="toggleModal('register-modal')" id="btn-nav-register"
        class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition shadow-sm block">Регистрация</button>

      <!-- Интерактивный блок Администратора (появляется при входе) -->
      <div id="user-profile-info" class="hidden flex items-center space-x-4 border-l border-slate-200 pl-4">

        <!-- НОВЫЕ КНОПКИ ДЛЯ АДМИНА (видны только роли ADMIN, управляются JS) -->
        <div id="admin-nav-buttons" class="hidden flex items-center space-x-2 mr-2">
          <button onclick="toggleModal('admin-panel')"
            class="text-xs bg-indigo-50 hover:bg-indigo-100 text-indigo-700 font-bold px-3 py-1.5 rounded-lg transition">➕
            Добавить книгу</button>
          <button onclick="toggleModal('admin-requests-panel')"
            class="text-xs bg-amber-50 hover:bg-amber-100 text-amber-700 font-bold px-3 py-1.5 rounded-lg transition flex items-center gap-1">📥
            Заявки</button>
          <button onclick="toggleModal('admin-users-panel')"
            class="text-xs bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold px-3 py-1.5 rounded-lg transition">👥
            Пользователи</button>
        </div>

        <div class="flex flex-col items-end">
          <span id="nav-user-name" class="text-sm font-semibold text-slate-700 leading-tight"></span>
          <span id="nav-user-role"
            class="text-[10px] uppercase tracking-wider bg-indigo-50 text-indigo-700 px-2 py-0.5 rounded-full font-bold mt-0.5"></span>
        </div>
        <button onclick="logout()"
          class="text-sm font-medium text-rose-600 hover:text-rose-700 transition bg-rose-50 hover:bg-rose-100 px-3 py-1.5 rounded-lg">Выйти</button>
      </div>
    </div>
  </div>
</nav>
