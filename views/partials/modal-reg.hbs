<div
  id='register-modal'
  class='hidden fixed inset-0 bg-slate-900/40 backdrop-blur-sm flex items-center justify-center z-50'
>
  <div
    class='bg-white rounded-2xl shadow-xl border border-slate-200 w-full max-w-md p-6 relative mx-4'
  >
    <button
      onclick="toggleModal('register-modal')"
      class='absolute top-4 right-4 text-slate-400 hover:text-slate-600 text-2xl font-semibold focus:outline-none'
    >&times;</button>
    <h3 class='text-xl font-bold text-slate-900 mb-4'>Создать аккаунт</h3>
    <form onsubmit='handleRegister(event)' class='space-y-4'>
      <div>
        <label
          class='block text-xs font-semibold text-slate-500 uppercase mb-1'
        >Полное имя (ФИО)</label>
        <input
          type='text'
          id='reg-name'
          required
          class='w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none'
        />
      </div>
      <div>
        <label
          class='block text-xs font-semibold text-slate-500 uppercase mb-1'
        >Email</label>
        <input
          type='email'
          id='reg-email'
          required
          class='w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none'
        />
      </div>
      <div>
        <label
          class='block text-xs font-semibold text-slate-500 uppercase mb-1'
        >Пароль</label>
        <input
          type='password'
          id='reg-password'
          required
          class='w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none'
        />
      </div>
      <button
        type='submit'
        class='w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2 rounded-lg text-sm transition shadow-sm'
      >Зарегистрироваться</button>
    </form>
  </div>
</div>