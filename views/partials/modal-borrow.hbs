<div id="borrow-modal" class="hidden fixed inset-0 bg-slate-900/40 backdrop-blur-sm flex items-center justify-center z-50">
    <div class="bg-white rounded-2xl shadow-xl border border-slate-200 w-full max-w-md p-6 relative mx-4">
        
        <!-- Кнопка закрытия -->
        <button onclick="toggleModal('borrow-modal')" class="absolute top-4 right-4 text-slate-400 hover:text-slate-600 text-2xl font-semibold focus:outline-none">&times;</button>
        
        <h3 class="text-xl font-bold text-slate-900 mb-2 text-center">Запрос на аренду книги</h3>
        <p id="borrow-modal-book-title" class="text-indigo-600 font-semibold text-center text-sm mb-5 px-4"></p>
        
        <form onsubmit="handleSendBorrowRequest(event)" class="space-y-5">
            <!-- Скрытое поле для ID книги -->
            <input type="hidden" id="borrow-modal-book-id">
            
            <div class="bg-indigo-50/50 p-4 rounded-xl border border-indigo-100/80">
                <label class="block text-xs font-bold text-indigo-700 uppercase mb-2 tracking-wider">Когда вы вернете книгу?</label>
                <input type="date" id="borrow-modal-date-picker" required
                       class="w-full px-3 py-2.5 border border-slate-300 rounded-xl text-sm font-medium focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white shadow-sm">
                <p class="text-[11px] text-slate-400 mt-1.5">⚠️ Пожалуйста, укажите дату возврата. Администратор библиотеки проверит вашу заявку.</p>
            </div>
            
            <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-3 rounded-xl text-sm transition shadow-sm font-bold flex items-center justify-center gap-2">
                🚀 Отправить запрос администратору
            </button>
        </form>
    </div>
</div>
